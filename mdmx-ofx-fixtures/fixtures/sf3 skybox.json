{
  "id" : "SF3 - Skybox - 2025 V1",
  "default_dmx_universe": 6,
  "default_dmx_channel": 201,

  "controls": [
    { "name": "Enable", "type": "float", "channel": 1 },

    { 
      "name": "Top Color", 
      "type": "rgb", 

      "red_channel": 3,
      "green_channel": 4,
      "blue_channel": 5,

      "default_color": { "r": 3, "g": 3, "b": 6 }
    },

    { 
      "name": "Horizon Color", 
      "type": "rgb", 

      "red_channel": 6,
      "green_channel": 7,
      "blue_channel": 8,

      "default_color": { "r": 5, "g": 8, "b": 22 }
    },

    { 
      "name": "Bottom Color", 
      "type": "rgb", 

      "red_channel": 9,
      "green_channel": 10,
      "blue_channel": 11,

      "default_color": { "r": 29, "g": 39, "b": 82 }
    },

    { 
      "name": "Aurora Hue", 
      "type": "float", 
      "channel": 12,
      "display_min": 0,
      "display_max": 255,
      "default_value": 43
    },

    { "name": "Aurora Intensity ", "type": "float", "channel": 13, "default_value": 1 },
    { "name": "Galaxy Intensity ", "type": "float", "channel": 14 },
    { "name": "Stars Intensity ", "type": "float", "channel": 15 },

    { "name": "FX Selection", "type": "float", "channel": 16 },
    { "name": "FX Transition ", "type": "float", "channel": 17 },
    { "name": "FX Bump 1", "type": "float", "channel": 18 },
    { "name": "FX Bump 2", "type": "float", "channel": 19 },

    { "name": "Video Mapping Mode", "type": "float", "channel": 20 },
    { "name": "Sky Shatter", "type": "float", "channel": 21 }
  ]
}
